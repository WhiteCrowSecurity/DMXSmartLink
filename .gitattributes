# PyArmor-obfuscated payloads + native libs + release zip: treat as binary so git
# never applies line-ending conversion (which would corrupt the embedded bytecode).
dist_*/**/*.py  -text
dist_*/**/*.so  binary
*.zip           binary
# macOS installer: binary, never line-ending-converted (gitignored, but defense-in-depth).
*.pkg binary

# Shell scripts run on Linux - keep LF
*.sh text eol=lf
